# =============================================================================
# avp-agent-identity — environment variables
# Copy this file to .env and fill in all values before running the stack.
# NEVER commit .env to version control.
#
# DB passwords and the Anthropic API key are NOT stored here.
# They live only in Bitwarden Secrets Manager and are injected at startup
# via `bws run`. See README for the startup command.
# =============================================================================

# --- Bitwarden Secrets Manager (bootstrap credentials) ---
# The only credentials the services need at startup.
# All application secrets (API keys, DB passwords) are injected by `bws run`
# or fetched from BWS by the app services at runtime.

# Chatbot agent machine account token — store in .env.local at project scope.
# Your personal developer BWS token belongs in ~/.zshrc, NOT here.
CHATBOT_BWS_TOKEN=

# Developer portal machine account token
DEVELOPER_BWS_TOKEN=

# Your Bitwarden organization ID (Settings > Organization ID in the web vault)
BWS_ORGANIZATION_ID=

# --- Amazon Verified Permissions (infrastructure config) ---
# Created by terraform/main.tf — run `terraform apply` first.
AVP_POLICY_STORE_ID=

# --- AWS credentials ---
# Used by both services to call AVP IsAuthorized.
# In production these would also live in BWS. For this demo they stay here
# as infrastructure config alongside AVP_POLICY_STORE_ID.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
