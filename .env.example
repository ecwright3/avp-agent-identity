# =============================================================================
# avp-agent-identity — environment variables
# Copy this file to .env and fill in all values before running the stack.
# NEVER commit .env to version control.
#
# This file contains no secrets. All secrets (API keys, DB passwords,
# AWS credentials) live only in Bitwarden Secrets Manager and are injected
# at startup via `bws run`. See README for the startup command.
#
# Your personal BWS_ACCESS_TOKEN belongs in ~/.zshrc, NOT here.
# It is used on the host to run `bws run` and is never passed into containers.
# =============================================================================

# --- Service machine account tokens ---
# Each service authenticates to BWS using its own scoped machine account.
# These are not your personal token. They are the identities the containers
# use to fetch their own secrets at startup.
CHATBOT_BWS_TOKEN=
DEVELOPER_BWS_TOKEN=

# --- Structural config (not secrets) ---
# These are identifiers and region settings, not credentials.
# Safe to share with your team. Still keep out of version control
# since this file also contains the machine account tokens above.
BWS_ORGANIZATION_ID=
AVP_POLICY_STORE_ID=
AWS_REGION=us-east-1
