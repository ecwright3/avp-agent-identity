# =============================================================================
# avp-agent-identity — environment variables
# Copy this file to .env and fill in all values before running the stack.
# NEVER commit .env to version control.
#
# This file contains no secrets. All secrets (API keys, DB password,
# AWS credentials) live only in Bitwarden Secrets Manager and are injected
# at startup via `bws run`. See README for the startup command.
#
# Your personal BWS_ACCESS_TOKEN belongs in ~/.zshrc, NOT here.
# =============================================================================

# --- Machine account tokens ---
# One per principal. These are not your personal token.
# They are the identities each process uses to fetch secrets from BWS.
KB_BWS_TOKEN=                  # kb-agent machine account token
SECURITY_ENGINEER_BWS_TOKEN=   # security-engineer machine account token

# --- Shared config (not secrets) ---
BWS_ORGANIZATION_ID=
AVP_POLICY_STORE_ID=           # output from terraform apply
AWS_REGION=us-east-1
